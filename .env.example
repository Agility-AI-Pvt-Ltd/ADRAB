# ════════════════════════════════════════════════════
# AI Document Review & Approval Tool — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────
APP_NAME="AI Document Review & Approval Tool"
APP_VERSION="1.0.0"
APP_DEBUG=false
AUTO_INIT_DB=true
API_V1_PREFIX="/api/v1"

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000,https://your-frontend-domain.com"

# ── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Only emails from this domain are allowed to sign in
ALLOWED_EMAIL_DOMAIN=agilityai.in
ALLOWED_EMAIL_EXCEPTIONS=kk612470@gmail.com

# ── Google OAuth ──────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=sdjnkc
GOOGLE_CLIENT_SECRET=msdnv
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=lyfshilp

# Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# ── OpenAI ────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000

# ── Local File Storage ────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json     # json | text
