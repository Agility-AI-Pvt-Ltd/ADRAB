# ════════════════════════════════════════════════════
# Lyfshilp AI DocTool — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────
APP_NAME="Lyfshilp AI DocTool API"
APP_VERSION="1.0.0"
DEBUG=false
API_V1_PREFIX="/api/v1"

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000,https://your-frontend-domain.com"

# ── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Only emails from this domain are allowed to sign in
ALLOWED_EMAIL_DOMAIN=agilityai.in

# ── Google OAuth ──────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=lyfshilp

# Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# ── Anthropic Claude ──────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2000

# ── AWS S3 (File Storage) ─────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=lyfshilp-docs
MAX_UPLOAD_SIZE_MB=10

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json     # json | text
